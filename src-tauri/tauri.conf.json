{
  "$schema": "https://raw.githubusercontent.com/nicehash/Tauri/v2/core/tauri-config-schema/schema.json",
  "productName": "CodeLens",
  "version": "0.1.0",
  "identifier": "com.codelens.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "CodeLens 代码阅读器",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
